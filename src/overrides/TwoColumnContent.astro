---
const { toc, entry, sidebar } = Astro.locals.starlightRoute;
import Sidebar from "./Sidebar.astro";
import MobileMenuOverlay from "@pelagornis/page/overrides/MobileMenuOverlay.astro";

// Check if sidebar exists
const hasSidebar = sidebar && sidebar.length > 0;
---

<main
  class={`page-main-container ${hasSidebar ? "with-sidebar" : "no-sidebar"} ${toc ? "with-toc" : "no-toc"}`}
>
  {
    hasSidebar && (
      <aside class="page-sidebar-nav">
        <Sidebar />
      </aside>
    )
  }

  {
    hasSidebar && (
      <button
        id="sidebar-collapse-toggle"
        class="sidebar-collapse-toggle ds-icon-btn"
        type="button"
        aria-label="Collapse sidebar"
        aria-expanded="true"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="3" width="12" height="10" rx="2" />
          <line x1="6.5" y1="3" x2="6.5" y2="13" />
        </svg>
      </button>
    )
  }

  <div
    class={`page-content-wrapper ${!hasSidebar ? "page-content-wrapper-full" : ""}`}
  >
    <slot />
  </div>

  {
    toc && (
      <aside class="page-toc-sidebar">
        <div class="page-toc-sticky">
          <slot name="right-sidebar" />
        </div>
      </aside>
    )
  }

  <MobileMenuOverlay />
</main>

{
  hasSidebar && (
    <script is:inline>
      (function () {
        var KEY = "sidebar_collapsed";
        function isCollapsed() {
          try {
            return localStorage.getItem(KEY) === "1";
          } catch (_) {
            return false;
          }
        }
        if (isCollapsed()) document.body.classList.add("sidebar-collapsed");

        function wire() {
          var toggle = document.getElementById("sidebar-collapse-toggle");
          if (!toggle || toggle.dataset.wired) return;
          toggle.dataset.wired = "1";
          toggle.addEventListener("click", function () {
            var collapsed = document.body.classList.toggle("sidebar-collapsed");
            toggle.setAttribute("aria-expanded", String(!collapsed));
            toggle.setAttribute("aria-label", collapsed ? "Expand sidebar" : "Collapse sidebar");
            try {
              localStorage.setItem(KEY, collapsed ? "1" : "0");
            } catch (_) {}
          });
        }
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", wire);
        } else {
          wire();
        }
      })();
    </script>
  )
}

<style>
  /* CSS variables */
  :root {
    --page-sidebar-width: 320px;
    --page-toc-width: 320px;
    --page-content-gap: var(--page-space-10);
    /* Flush against the viewport edge, same as the left sidebar — a floating
       card offset from the edge is what made this panel read as a different
       system from the sidebar it sits opposite. */
    --page-toc-right-margin: 0px;
    --page-toc-top-position: 88px;
    --page-toc-height: calc(100vh - 104px);
  }

  /* Dynamic sizing by viewport */
  @media (min-width: 1600px) and (max-width: 1999px) {
    :root {
      --page-toc-width: 300px;
      --page-content-gap: var(--page-space-8);
    }
  }

  @media (min-width: 2000px) and (max-width: 2399px) {
    :root {
      --page-toc-width: 320px;
      --page-content-gap: var(--page-space-10);
    }
  }

  @media (min-width: 2400px) {
    :root {
      --page-toc-width: 360px;
      --page-content-gap: var(--page-space-12);
    }
  }

  /* Layout wrapper */
  .page-layout-wrapper {
    min-height: 100vh;
    background: var(--page-bg);
  }

  /* Main container - min-width: 0 so it can shrink when chat panel is open */
  .page-main-container {
    display: flex;
    min-height: calc(100vh - var(--page-header-height));
    min-width: 0;
    position: relative;
  }

  /* With sidebar */
  .page-main-container.with-sidebar {
    gap: var(--page-content-gap);
  }

  /* Without sidebar */
  .page-main-container.no-sidebar {
    gap: 0;
  }

  /* With TOC */
  .page-main-container.with-toc {
    gap: var(--page-content-gap);
  }

  /* Without TOC */
  .page-main-container.no-toc {
    gap: var(--page-content-gap);
  }

  /* Left sidebar (narrow) — a distinct surface, not the same tone as the
     content it sits beside, plus the hairline the mobile drawer already had.
     Scroll ownership lives on Sidebar.astro's own .page-sidebar-container
     now (it needs a pinned header row above the scrolling nav list), so this
     outer panel just clips to its own rounded corners. */
  .page-sidebar-nav {
    width: var(--page-sidebar-width);
    flex-shrink: 0;
    background: var(--page-bg-secondary);
    border-right: 1px solid var(--page-border);
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease;
  }

  /* Show sidebar on desktop (narrow) — spans the full viewport height,
     including the row the top header occupies (the header's own copy of the
     site title is hidden at this width; the sidebar's built-in header row
     is what's visible there now — see Sidebar.astro). Corners are "notched":
     flush against the left/top/bottom viewport edges, rounded only on the
     two corners that face the content area. */
  @media (min-width: 769px) {
    .page-sidebar-nav {
      position: fixed;
      top: 0;
      left: 0;
      height: 100vh;
      /* Clears .header's real z-index (100, set in PageFrame.astro — not
         .page-header's locally-scoped 1000, which only orders that
         component's own children) so the sidebar draws over the header's
         left column instead of under it. */
      z-index: 150;
      transform: translateX(0);
      width: var(--page-sidebar-width);
      border-radius: 0 var(--page-radius-lg) var(--page-radius-lg) 0;
    }
  }

  /* Between 769–1024px the chat panel opens as a full-width bottom sheet
     (z-index 50, in the vendor's ChatPane) that spatially overlaps the
     sidebar's lower ~70%. The sidebar's new z-index:150 would otherwise draw
     over that open sheet — drop back below it in just this band, where the
     header (the thing z-index:150 actually needs to clear) never overlaps
     the chat sheet anyway, so nothing is lost by lowering it here. */
  @media (max-width: 1024px) {
    :global(body.page-chat-open) .page-sidebar-nav {
      z-index: 10;
    }
  }

  /* Hide sidebar on mobile (access via hamburger only) */
  @media (max-width: 768px) {
    .page-main-container {
      flex-direction: column;
      padding: 0;
    }

    .page-sidebar-nav {
      position: fixed;
      top: var(--page-header-height, 64px);
      left: 0;
      width: 200px;
      height: calc(100vh - var(--page-header-height, 64px));
      background: var(--page-bg-secondary);
      border-right: 1px solid var(--page-border);
      z-index: 1000;
      transform: translateX(-100%);
      transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      overflow-y: auto;
      box-shadow: var(--page-shadow-lg);
      display: block !important;
      visibility: visible !important;
    }

    .page-sidebar-nav[data-open="true"] {
      transform: translateX(0);
    }

    .page-content-wrapper {
      width: 100%;
      padding: 0 var(--page-space-4);
      margin-left: 0;
      min-width: 0;
      max-width: 100%;
    }
  }

  /* Content wrapper - responsive */
  .page-content-wrapper {
    flex: 1;
    min-height: calc(100vh - var(--page-header-height));
    width: 100%;
    padding-top: var(--page-space-6);
    min-width: 0;
  }

  /* Full width on index page */
  .page-content-wrapper-full {
    margin-left: 0 !important;
    width: 100% !important;
    max-width: 1200px !important;
    margin: 0 auto !important;
    padding: 0 var(--page-space-8) !important;
  }

  /* Index page padding on mobile */
  @media (max-width: 768px) {
    .page-content-wrapper-full {
      padding: 0 var(--page-space-4) !important;
    }
  }

  /* Responsive max-width */
  @media (min-width: 1400px) {
    .page-content-wrapper-full {
      max-width: 1400px !important;
    }
  }

  @media (min-width: 1600px) {
    .page-content-wrapper-full {
      max-width: 1600px !important;
    }
  }

  .page-single-column {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--page-space-6) var(--page-space-8);
    animation: pageFadeIn 0.3s ease-out;
    background: var(--page-bg);
    flex: 1;
    width: 100%;
  }

  .page-two-column-layout {
    position: relative;
    padding: var(--page-space-6) var(--page-space-8);
    animation: pageFadeIn 0.3s ease-out;
    background: var(--page-bg);
    min-height: calc(100vh - var(--page-header-height));
    flex: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--page-space-8);
  }

  /* Max width on very large screens */
  @media (min-width: 2000px) {
    .page-main-container {
      max-width: 1800px;
      margin: 0 auto;
    }
  }

  /* Wider max width on extra-large screens */
  @media (min-width: 2400px) {
    .page-main-container {
      max-width: 2000px;
      margin: 0 auto;
    }
  }

  /* Move TOC above on medium screens - responsive */
  @media (min-width: 768px) and (max-width: 1279px) {
    .page-main-container {
      flex-direction: column;
      gap: var(--page-space-8);
      width: 100%;
      max-width: 100%;
      margin: 0;
      padding: var(--page-space-6);
    }

    .page-content-wrapper {
      margin-left: var(--page-sidebar-width);
      width: calc(100% - var(--page-sidebar-width));
      min-width: 0;
      order: 2;
    }

    .page-toc-sidebar {
      order: 1;
      margin-bottom: var(--page-space-8);
      width: 100%;
      display: none !important;
    }

    .page-toc-sticky {
      position: relative;
      top: auto;
      max-height: none;
      margin: 0;
      width: 100%;
    }
  }

  /* When chat open: use column layout below 1640px to avoid layout break */
  :global(body.page-chat-open) .page-main-container {
    min-width: 0;
  }

  @media (min-width: 768px) and (max-width: 1639px) {
    :global(body.page-chat-open) .page-main-container {
      flex-direction: column;
      gap: var(--page-space-8);
      width: 100%;
      max-width: 100%;
      margin: 0;
      padding: var(--page-space-6);
    }

    :global(body.page-chat-open) .page-content-wrapper {
      margin-left: var(--page-sidebar-width);
      width: calc(100% - var(--page-sidebar-width));
      min-width: 0;
      max-width: 100%;
      order: 2;
    }

    :global(body.page-chat-open) .page-toc-sidebar {
      order: 1;
      margin-bottom: var(--page-space-8);
      width: 100%;
      display: none !important;
    }

    :global(body.page-chat-open) .page-toc-sticky {
      position: relative;
      top: auto;
      max-height: none;
      margin: 0;
      width: 100%;
    }
  }

  /* Max width on medium screens */
  @media (min-width: 1200px) and (max-width: 1599px) {
    .page-main-container {
      max-width: 1200px;
      margin: 0 auto;
    }
  }

  /* TOC on right on large screens */
  @media (min-width: 1280px) {
    .page-main-container {
      display: flex;
      flex-direction: row;
      gap: var(--page-content-gap);
      width: 100%;
      max-width: 100%;
      margin: 0;
      padding: var(--page-space-10);
    }

    .page-content-wrapper {
      flex: 1;
      margin-left: var(--page-sidebar-width);
      width: auto;
      min-width: 0;
      max-width: none;
      margin-right: 5rem;
    }

    .page-toc-sidebar {
      display: block !important;
      position: fixed;
      right: var(--page-toc-right-margin);
      top: var(--page-toc-top-position);
      width: var(--page-toc-width);
      height: var(--page-toc-height);
      z-index: 99;
    }
  }

  @media (min-width: 1536px) {
    .page-two-column-layout {
      max-width: 1800px;
      gap: 3rem;
    }
  }

  @media (min-width: 1920px) {
    .page-two-column-layout {
      max-width: 2000px;
      gap: 4rem;
    }
  }

  .page-content-area {
    min-width: 0;
    position: relative;
  }

  .page-toc-sidebar {
    display: block;
    width: 320px;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .page-toc-sidebar {
      display: block;
      position: relative;
    }
  }

  /* Same flat, hairline-bordered, edge-attached surface as .page-sidebar-nav
     — flush to the viewport's right edge, no shadow — so the two rails
     flanking the content read as one system instead of "flat panel" on one
     side and "floating rounded card" on the other. Corners are "notched"
     the same way the sidebar's are: square on the outer/right edge, rounded
     only on the two corners that face the content. */
  .page-toc-sticky {
    position: fixed;
    top: calc(var(--page-header-height) + var(--page-space-8));
    height: calc(100vh - var(--page-header-height) - var(--page-space-8));
    overflow-y: auto;
    padding: var(--page-space-6);
    background: var(--page-bg-secondary);
    border-left: 1px solid var(--page-border);
    border-radius: var(--page-radius-lg) 0 0 var(--page-radius-lg);
  }

  /* TOC title style */
  .page-toc-sticky :global(h2) {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--page-text);
    margin: 0 0 var(--page-space-4) 0;
    padding-bottom: var(--page-space-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* TOC link style */
  .page-toc-sticky :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .page-toc-sticky :global(li) {
    margin: 0;
  }

  .page-toc-sticky :global(a) {
    display: block;
    padding: var(--page-space-2) 0;
    color: var(--page-text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    line-height: 1.4;
    transition: all 0.2s ease;
    border-radius: var(--page-radius-lg);
    margin: 2px 0;
  }

  .page-toc-sticky :global(a:hover) {
    color: var(--page-text);
    background: var(--page-accent-light);
    padding-left: var(--page-space-2);
  }

  .page-toc-sticky :global(a[aria-current="true"]) {
    color: var(--page-accent);
    font-weight: 500;
    background: var(--page-accent-light);
    padding-left: var(--page-space-2);
  }

  /* TOC indent by depth */
  .page-toc-sticky :global(ul ul) {
    margin-left: var(--page-space-4);
    border-left: 1px solid var(--page-border);
    padding-left: var(--page-space-2);
  }

  /* Page-style TOC scrollbar */
  .page-toc-sticky::-webkit-scrollbar {
    width: 4px;
  }

  .page-toc-sticky::-webkit-scrollbar-track {
    background: transparent;
  }

  .page-toc-sticky::-webkit-scrollbar-thumb {
    background: var(--page-border);
    border-radius: 2px;
  }

  .page-toc-sticky::-webkit-scrollbar-thumb:hover {
    background: var(--page-text-secondary);
  }

  /* Page-style TOC link - simplified */
  :global(.page-toc-sticky .sl-toc) {
    font-size: 0.875rem;
  }

  :global(.page-toc-sticky .sl-toc a) {
    color: var(--page-text-secondary) !important;
    text-decoration: none !important;
    display: block !important;
    padding: var(--page-space-2) 0 !important;
    border-radius: var(--page-radius-lg) !important;
    transition: all 0.2s ease !important;
    margin: 2px 0 !important;
  }

  :global(.page-toc-sticky .sl-toc a:hover) {
    color: var(--page-text) !important;
    background: var(--page-accent-light) !important;
    padding-left: var(--page-space-2) !important;
  }

  :global(.page-toc-sticky .sl-toc a[aria-current="true"]) {
    color: var(--page-accent) !important;
    background: var(--page-accent-light) !important;
    padding-left: var(--page-space-2) !important;
    font-weight: 500 !important;
  }

  /* Page-style TOC title */
  :global(.page-toc-sticky .sl-toc > summary) {
    color: var(--page-text) !important;
    font-weight: 600 !important;
    font-size: 0.875rem !important;
    margin-bottom: var(--page-space-4) !important;
    padding-bottom: var(--page-space-2) !important;
    border-bottom: 1px solid var(--page-border) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
  }

  /* Page-style nested TOC */
  :global(.page-toc-sticky .sl-toc ul) {
    list-style: none !important;
    margin-left: var(--page-space-4) !important;
    border-left: 1px solid var(--page-border) !important;
    padding-left: var(--page-space-2) !important;
  }

  :global(.page-toc-sticky .sl-toc ul a) {
    font-size: 0.8125rem !important;
  }

  /* Starlight default TOC fixed below header */
  :global(.sl-toc:not(.sl-toc-mobile)) {
    position: fixed !important;
    top: calc(var(--page-header-height) + var(--page-space-4)) !important;
    left: var(--page-sidebar-width) !important;
    right: var(--page-space-4) !important;
    z-index: 100 !important;
    max-height: calc(
      100vh - var(--page-header-height) - var(--page-space-8)
    ) !important;
    overflow-y: auto !important;
  }

  /* Starlight default TOC title - keep original design */
  :global(.sl-toc > summary) {
    display: flex !important;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--page-space-3) var(--page-space-4);
    background: var(--page-bg-secondary);
    border: 1px solid var(--page-border);
    border-radius: var(--page-radius-lg);
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--page-text);
    margin-bottom: var(--page-space-4);
  }

  /* Starlight default TOC list - keep original design */
  :global(.sl-toc ul) {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  :global(.sl-toc li) {
    margin: 0 !important;
  }

  :global(.sl-toc a) {
    display: block !important;
    padding: var(--page-space-2) 0 !important;
    color: var(--page-text-secondary) !important;
    text-decoration: none !important;
    font-size: 0.875rem !important;
    line-height: 1.4 !important;
    transition: all 0.2s ease !important;
    border-radius: var(--page-radius-lg) !important;
    margin: 2px 0 !important;
  }

  :global(.sl-toc a:hover) {
    color: var(--page-text) !important;
    background: var(--page-accent-light) !important;
    padding-left: var(--page-space-2) !important;
  }

  :global(.sl-toc a[aria-current="true"]) {
    color: var(--page-accent) !important;
    background: var(--page-accent-light) !important;
    padding-left: var(--page-space-2) !important;
    font-weight: 500 !important;
  }

  /* TOC position on mobile */
  @media (max-width: 767px) {
    .page-toc-sidebar {
      display: none !important;
    }

    /* Hide TOC on mobile */
    :global(.sl-toc:not(.sl-toc-mobile)) {
      display: none !important;
    }

    /* Top margin for content */
    .page-content-wrapper {
      padding-top: var(--page-header-height);
    }
  }

  /* Hide TOC on medium screens */
  @media (min-width: 768px) and (max-width: 1279px) {
    .page-toc-sidebar {
      display: none !important;
    }

    /* Hide TOC on medium too */
    :global(.sl-toc:not(.sl-toc-mobile)) {
      display: none !important;
    }

    /* Content margin on medium screens */
    .page-content-wrapper {
      padding-top: calc(var(--page-header-height));
    }
  }

  /* TOC in dark theme */
  [data-theme="dark"] :global(.sl-toc) {
    background: var(--page-bg) !important;
    border-color: var(--page-border) !important;
  }

  [data-theme="dark"] :global(.sl-toc > summary) {
    background: var(--page-bg) !important;
    border-color: var(--page-border) !important;
    color: var(--page-text) !important;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .page-single-column,
    .page-two-column-layout {
      padding: var(--page-space-6) var(--page-space-4);
    }
  }

  /* Page container style */
  .page-content-area {
    background: var(--page-bg);
    border-radius: var(--page-radius-lg);
    position: relative;
  }

  /* Remove card style on small screens */
  @media (max-width: 1279px) {
    .page-content-area {
      background: transparent;
      border-radius: 0;
    }
  }

  /* Page-style page transition animation */
  @keyframes pageFadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Wider margin on large screens */
  @media (min-width: 2560px) {
    .page-two-column-layout {
      max-width: 2400px;
      gap: 5rem;
    }

    .page-single-column {
      max-width: 1400px;
    }
  }

  /* Sidebar collapse toggle — sits on the sidebar's own header-row seam
     (vertically centered in the same var(--page-header-height) band as
     Sidebar.astro's .page-sidebar-header), at its right edge. Visual shape
     (background/radius/hover) comes from the shared .ds-icon-btn primitive;
     only position/size is scoped here. Desktop only: mobile already has the
     hamburger for this job. Stays a DOM sibling of <Sidebar/>, not a child
     of it, on purpose — .page-sidebar's innerHTML gets cloned into the
     mobile drawer, and a cloned button would lose its click handler. */
  .sidebar-collapse-toggle {
    display: none;
  }

  @media (min-width: 769px) {
    .sidebar-collapse-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      position: fixed;
      top: calc(var(--page-header-height) / 2);
      left: var(--page-sidebar-width);
      transform: translate(-50%, -50%);
      width: 32px;
      height: 32px;
      padding: 0;
      cursor: pointer;
      /* Above the sidebar (150) so it's never covered, expanded or collapsed. */
      z-index: 160;
      transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .sidebar-collapse-toggle:focus-visible {
      outline: 2px solid var(--sl-color-accent);
      outline-offset: 2px;
    }

    .sidebar-collapse-toggle svg {
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Collapsed state: slide the panel off, let content reclaim the width,
       flip the handle to the edge and its chevron to point the other way. */
    body.sidebar-collapsed .page-sidebar-nav {
      transform: translateX(-100%);
      opacity: 0;
      pointer-events: none;
    }

