---
// Page-style header layout
import Search from "@pelagornis/page/overrides/Search.astro";
import ChatButton from "./ChatButton.astro";
import SocialIcons from "@pelagornis/page/overrides/SocialIcons.astro";

const showChat = true; // docChat is enabled via pagePlugin config
import MobileMenuToggle from "@pelagornis/page/overrides/MobileMenuToggle.astro";
import LanguageSelect from "@pelagornis/page/overrides/LanguageSelect.astro";
import ThemeSelect from "@pelagornis/page/overrides/ThemeSelect.astro";
import config from "virtual:starlight/user-config";
import { logos } from "virtual:starlight/user-images";

// Build path considering locale
function localizedPath(path: string): string {
  const currentLocale = Astro.locals.starlightRoute?.locale;

  // If no currentLocale or 'en', return path without locale
  if (!currentLocale || currentLocale === config.defaultLocale.locale) {
    return path;
  }

  // For other locales, return path with locale prefix
  return `/${currentLocale}${path}`;
}

// Get navigation from env
let navigation: { href: string; label: string }[] | undefined;
try {
  const navigationEnv = process.env.PAGE_NAVIGATION;
  navigation = navigationEnv ? JSON.parse(navigationEnv) : undefined;
} catch {
  navigation = undefined;
}

const { siteTitle, siteTitleHref, sidebar } = Astro.locals.starlightRoute;

// Check if sidebar exists
const hasSidebar = sidebar && sidebar.length > 0;
---

<div class="page-header">
  <div class="page-header-container">
    <div class="page-header-left">
      <!-- Page-style site title -->
      <a href={siteTitleHref} class="page-site-title">
        {
          config.logo && logos.dark && (
            <>
              <img
                class:list={[
                  { "light:sl-hidden": !("src" in config.logo) },
                  "logo-size",
                ]}
                alt={config.logo.alt}
                src={logos.dark.src}
                width={logos.dark.width}
                height={logos.dark.height}
              />
              {/* Show light alternate if a user configure both light and dark logos. */}
              {!("src" in config.logo) && (
                <img
                  class="dark:sl-hidden logo-size"
                  alt={config.logo.alt}
                  src={logos.light?.src}
                  width={logos.light?.width}
                  height={logos.light?.height}
                />
              )}
            </>
          )
        }
        <span class="page-title-text">{siteTitle}</span>
      </a>

      <!-- Page-style navigation -->
      {
        navigation && (
          <nav class="page-nav">
            {navigation.map((item: { href: string; label: string }) => (
              <a href={localizedPath(item.href)} class="page-nav-link">
                {item.label}
              </a>
            ))}
          </nav>
        )
      }
    </div>

    <div class="page-header-right">
      <!-- Page-style search -->
      <div class="page-search-wrapper">
        <Search />
      </div>
      {showChat && <ChatButton />}

      <!-- Page-style theme toggle -->
      <ThemeSelect />

      <!-- Page-style language select -->
      <LanguageSelect />

      <!-- Page-style social links -->
      <SocialIcons />

      <!-- Page-style mobile menu toggle -->
      {hasSidebar && <MobileMenuToggle />}
    </div>
  </div>
</div>

<script>
  // Store event listener refs in module scope
  let isInitialized = false;
  let themeToggleHandler: (() => void) | null = null;
  let astroPageLoadHandler: (() => void) | null = null;

  // Page-style theme toggle (replaced by ThemeSelect component)
  function initpageThemeToggle() {
    // ThemeSelect handles theme toggle; here we only run init
    // Add extra logic here if needed
  }

  // Page-style active navigation
  function setpageActiveNavLink() {
    const currentPath = window.location.pathname;
    const navLinks = document.querySelectorAll(".page-nav-link");

    navLinks.forEach((link) => {
      link.classList.remove("active");
      const href = link.getAttribute("href");

      // More precise active link matching
      if (href === "/" && currentPath === "/") {
        link.classList.add("active");
      } else if (href !== "/" && href && currentPath.startsWith(href)) {
        link.classList.add("active");
      }
    });
  }

  // Logo theme change
  function updateLogo() {
    const logo = document.querySelector(".page-logo") as HTMLImageElement;
    if (!logo) return;

    const isDark =
      document.documentElement.getAttribute("data-theme") === "dark";
    const logoLight = logo.dataset.logoLight;
    const logoDark = logo.dataset.logoDark;

    if (logoDark && isDark) {
      logo.src = logoDark;
    } else if (logoLight && !isDark) {
      logo.src = logoLight;
    }
  }

  // Init function
  function initializeHeader() {
    // Prevent duplicate initialization
    if (isInitialized) {
      return;
    }

    initpageThemeToggle();
    setpageActiveNavLink();
    updateLogo();

    // Listen for theme change
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (
          mutation.type === "attributes" &&
          mutation.attributeName === "data-theme"
        ) {
          updateLogo();
        }
      });
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });

    isInitialized = true;
  }

  // Cleanup function
  function cleanup() {
    const toggleButton = document.getElementById(
      "page-theme-toggle",
    ) as HTMLButtonElement;

    if (toggleButton && themeToggleHandler) {
      toggleButton.removeEventListener("click", themeToggleHandler);
      themeToggleHandler = null;
    }

    if (astroPageLoadHandler) {
      document.removeEventListener("astro:page-load", astroPageLoadHandler);
      astroPageLoadHandler = null;
    }

    isInitialized = false;
  }

  // Initialize
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeHeader);
  } else {
    initializeHeader();
  }

  // Run on Astro page change too (after cleaning existing listeners)
  if (!astroPageLoadHandler) {
    astroPageLoadHandler = () => {
      cleanup();
      initializeHeader();
    };
    document.addEventListener("astro:page-load", astroPageLoadHandler);
  }

  // Cleanup on page unload
  window.addEventListener("beforeunload", cleanup);
</script>

<style>
  /* Page-style header — same flat, hairline-bordered surface as the sidebar
     and TOC (.ds-panel's recipe), not a glass/blur treatment found nowhere
     else in the app. */
  .page-header {
    position: relative;
    top: 0;
    left: 0;
    right: 0;
    height: var(--page-header-height);
    background: var(--page-bg-secondary);
    border-bottom: 1px solid var(--page-border);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .page-header-container {
    max-width: 1440px;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--page-space-8);
  }

  .page-header-left {
    display: flex;
    align-items: center;
    gap: var(--page-space-10);
  }

  .page-header-right {
    display: flex;
    align-items: center;
    gap: var(--page-space-2);
  }

  /* Nav icon buttons: same 40x40 as SocialIcons (Slack etc), icon 20px */
  .page-header-right .page-search-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .page-header-right page-select,
  .page-header-right .page-language-select {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .page-header-right .page-theme-toggle-button,
  .page-header-right .page-search-button,
  .page-header-right .page-chat-button,
  .page-header-right .page-language-select-button,
  .page-header-right .page-mobile-menu-toggle {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 40px !important;
    height: 40px !important;
    min-width: 40px !important;
    min-height: 40px !important;
    padding: var(--page-space-3) !important;
    border: none !important;
    border-radius: var(--page-radius-lg) !important;
    background: var(--page-accent-light) !important;
    color: var(--page-text-secondary) !important;
    box-sizing: border-box !important;
  }

  .page-header-right .page-theme-toggle-button:hover,
  .page-header-right .page-search-button:hover,
  .page-header-right .page-chat-button:hover,
  .page-header-right .page-language-select-button:hover,
  .page-header-right .page-mobile-menu-toggle:hover {
    background: var(--page-text-reverse) !important;
    color: var(--page-text) !important;
    transform: translateY(-1px) !important;
    box-shadow: var(--page-shadow-sm) !important;
  }

  /* RefineUI (font icon) glyphs appear small; use 24px to match Slack (SVG) */
  .page-header-right .page-theme-toggle-button span,
  .page-header-right .page-theme-toggle-button .refineui-icon,
  .page-header-right .page-search-button span,
  .page-header-right .page-search-button .refineui-icon,
  .page-header-right .page-chat-button span,
  .page-header-right .page-chat-button .refineui-icon,
  .page-header-right .page-language-select-button span,
  .page-header-right .page-language-select-button .refineui-icon,
  .page-header-right .page-mobile-menu-toggle span,
  .page-header-right .page-mobile-menu-toggle .refineui-icon {
    width: 24px !important;
    height: 24px !important;
    min-width: 24px !important;
    min-height: 24px !important;
    flex-shrink: 0;
    font-size: 24px !important;
    line-height: 1 !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .page-header-right .page-search-button svg,
  .page-header-right .page-chat-button svg,
  .page-header-right .page-theme-toggle-button svg,
  .page-header-right .page-language-select-button svg,
  .page-header-right .page-mobile-menu-toggle svg {
    width: 24px !important;
    height: 24px !important;
    min-width: 24px !important;
    min-height: 24px !important;
    flex-shrink: 0;
  }

  /* SocialIcons (Slack, GitHub) SVG also 24px */
  .page-header-right a svg {
    width: 24px !important;
    height: 24px !important;
    min-width: 24px !important;
    min-height: 24px !important;
  }

  /* Page-style site title — lives in the sidebar now (Sidebar.astro) at
     desktop widths, where the sidebar spans the full viewport height and
     covers this header's left column. Stays visible here on mobile (the
     sidebar's full-height treatment is desktop-only) and reappears here the
     moment the sidebar is collapsed, so there's still a way home.

     Ordering matters: the hiding rule below has the same specificity
     (0-1-0) as this base rule, so it must come AFTER it in source order to
     win at desktop widths — .sidebar-collapsed then out-specifies both. */
  .page-site-title {
    display: flex;
    align-items: center;
    gap: var(--page-space-3);
    text-decoration: none;
    color: var(--page-text);
    font-weight: 700;
    font-size: 1.125rem;
    transition: opacity 0.2s ease;
  }

  @media (min-width: 769px) {
    .page-site-title {
      display: none;
    }
  }

  :global(body.sidebar-collapsed) .page-site-title {
    display: flex;
  }

  .page-site-title:hover {
    opacity: 0.7;
  }

  .page-logo {
    width: 32px;
    height: 32px;
    border-radius: var(--page-radius-sm);
  }

  /* Starlight logo-size class style */
  .logo-size {
    width: 32px;
    height: 32px;
    border-radius: var(--page-radius-sm);
  }

  .page-title-text {
    font-family: var(--page-font-family);
    letter-spacing: -0.02em;
  }

  /* Page-style navigation */
  .page-nav {
    display: flex;
    align-items: center;
    gap: var(--page-space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .page-nav-link {
    display: inline-flex;
    align-items: center;
    padding: var(--page-space-2) var(--page-space-4);
    border-radius: var(--page-radius-lg);
    text-decoration: none;
    color: var(--page-text-secondary);
    font-weight: 500;
    font-size: 0.875rem;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .page-nav-link:hover {
    color: var(--page-text);
    background: var(--page-accent-light);
  }

  /* Active state uses an explicit accent tint, not --page-accent-light —
     that token is a neutral hover surface shared by every icon button, not
     an "active" indicator (see theme.css). */
  .page-nav-link.active {
    color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
    font-weight: 600;
  }

  /* Page-style button */
  .page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--page-space-3);
    border: none;
    border-radius: var(--page-radius-lg);
    background: var(--page-accent-light);
    color: var(--page-text-secondary);
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    font-weight: 500;
    text-decoration: none;
  }

  .page-btn:hover {
    background: var(--page-neutral-200);
    color: var(--page-text);
    transform: translateY(-1px);
  }

  [data-theme="dark"] .page-btn:hover {
    background: var(--page-neutral-800);
  }

  .page-btn-primary {
    background: var(--page-accent);
    color: var(--page-bg);
    width: 40px;
    height: 40px;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .page-btn-primary:hover {
    background: var(--page-accent-hover);
    transform: translateY(-1px);
  }

  [data-theme="dark"] .page-btn-primary {
    background: var(--page-accent) !important;
    color: var(--page-bg) !important;
  }

  [data-theme="dark"] .page-btn-primary:hover {
    background: var(--page-neutral-300) !important;
    color: var(--page-bg) !important;
  }

  /* GitHub button specific style */
  [data-theme="dark"] .page-github-btn {
    background: var(--page-accent) !important;
    color: var(--page-bg) !important;
  }

  [data-theme="dark"] .page-github-btn:hover {
    background: var(--page-neutral-300) !important;
    color: var(--page-bg) !important;
  }

  .page-btn svg {
    width: 20px;
    height: 20px;
  }

  /* Page-style theme toggle */
  .page-theme-toggle {
    width: 40px;
    height: 40px;
    border: none;
    border-radius: var(--page-radius-lg);
    background: var(--page-accent-light);
    color: var(--page-text-secondary);
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .page-theme-toggle:hover {
    background: var(--page-neutral-200);
    color: var(--page-text);
    transform: translateY(-1px);
  }

  [data-theme="dark"] .page-theme-toggle:hover {
    background: var(--page-neutral-800);
  }

  .page-theme-toggle svg {
    width: 18px;
    height: 18px;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .page-header-container {
      padding: 0 var(--page-space-4);
    }

    .page-header-left {
      gap: var(--page-space-4);
    }

    .page-nav {
      display: none;
    }

    .page-title-text {
      display: none;
    }

    .page-mobile-menu-toggle {
      display: flex !important;
    }

    /* Mobile: nav/menu button 32px touch target (incl. Social Icons) */
    .page-header-right .page-theme-toggle-button,
    .page-header-right .page-search-button,
    .page-header-right .page-chat-button,
    .page-header-right .page-language-select-button,
    .page-header-right .page-mobile-menu-toggle,
    .page-header-right a {
      width: 32px !important;
      height: 32px !important;
      min-width: 32px !important;
      min-height: 32px !important;
      padding: var(--page-space-2) !important;
    }

    /* Mobile: RefineUI icon 20px only (button touch stays 32px) */
    .page-header-right .page-theme-toggle-button span,
    .page-header-right .page-theme-toggle-button .refineui-icon,
    .page-header-right .page-search-button span,
    .page-header-right .page-search-button .refineui-icon,
    .page-header-right .page-chat-button span,
    .page-header-right .page-chat-button .refineui-icon,
    .page-header-right .page-language-select-button span,
    .page-header-right .page-language-select-button .refineui-icon,
    .page-header-right .page-mobile-menu-toggle span,
    .page-header-right .page-mobile-menu-toggle .refineui-icon,
    .page-header-right .page-mobile-menu-toggle .page-menu-icon {
      width: 20px !important;
      height: 20px !important;
      min-width: 20px !important;
      min-height: 20px !important;
      font-size: 20px !important;
    }

    .page-header-right .page-search-button svg,
    .page-header-right .page-chat-button svg,
    .page-header-right .page-theme-toggle-button svg,
    .page-header-right .page-language-select-button svg,
    .page-header-right .page-mobile-menu-toggle svg {
      width: 20px !important;
      height: 20px !important;
      min-width: 20px !important;
      min-height: 20px !important;
    }

    .page-header-right a svg {
      width: 20px !important;
      height: 20px !important;
      min-width: 20px !important;
      min-height: 20px !important;
    }

    /* Mobile animation tuning */
    .page-btn,
    .page-theme-toggle,
    .page-mobile-menu-toggle {
      transition: none !important;
      will-change: auto !important;
    }

    .page-btn:hover,
    .page-theme-toggle:hover,
    .page-mobile-menu-toggle:hover {
      transform: none !important;
    }
  }

  @media (min-width: 769px) {
    .page-mobile-menu-toggle {
      display: none !important;
    }
  }

  /* Extra tuning for very small screens */
  @media (max-width: 480px) {
    .page-header-container {
      padding: 0 var(--page-space-3);
    }

    .page-header-left {
      gap: var(--page-space-3);
    }

    .page-site-title {
      font-size: 1rem;
    }

    .page-logo {
      width: 28px;
      height: 28px;
    }
  }
</style>
