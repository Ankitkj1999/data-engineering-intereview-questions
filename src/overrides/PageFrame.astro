---
// PageFrame.astro
import ChatPane from "@pelagornis/page/components/ChatPane.astro";

const footerText =
  process.env.PAGE_FOOTER_TEXT ||
  `© ${new Date().getFullYear()} Pelagornis Inc. All rights reserved.`;

const chatProvider = "gemini" as "openai" | "claude" | "gemini";
const chatModel = import.meta.env.PUBLIC_DOC_CHAT_MODEL;
const showChat = true; // docChat is enabled via pagePlugin config
const chatBase = (process.env.PAGE_BASE ?? "").replace(/\/$/, "") || "";
const locale =
  (Astro.locals.starlightRoute as { locale?: string } | undefined)?.locale ??
  "en";
---

{
  showChat ? (
    <div class="page page-has-chat sl-flex">
      {/* Header + Content + Footer group → shrinks together when chat is open */}
      <div class="page-nav-wrap">
        <header class="header">
          <slot name="header" />
        </header>
        <div class="page-scroll-wrap">
          <main class="main-frame">
            <slot />
          </main>
          <footer class="page-footer">
            <div class="page-footer-content">
              <div class="page-footer-left">
                <p class="page-footer-copyright">{footerText}</p>
              </div>
            </div>
          </footer>
        </div>
      </div>
      {/* Chat in separate wrapper */}
      <ChatPane
        basePath={chatBase}
        provider={chatProvider}
        model={chatModel}
        locale={locale}
      />
    </div>
  ) : (
    <div class="page sl-flex">
      <header class="header">
        <slot name="header" />
      </header>
      <div class="page-scroll-wrap">
        <main class="main-frame">
          <slot />
        </main>
        <footer class="page-footer">
          <div class="page-footer-content">
            <div class="page-footer-left">
              <p class="page-footer-copyright">{footerText}</p>
            </div>
          </div>
        </footer>
      </div>
    </div>
  )
}

<style>
  /* Page layout: viewport height fixed, only main+footer scroll */
  .page {
    height: 100vh;
    width: 100%;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* With chat: [ Header+Content+Footer | Chat ] horizontal; header reacts too */
  .page-has-chat {
    flex-direction: row;
    flex-wrap: nowrap;
    overflow-x: hidden;
  }

  /* Nav area = Header + (scroll area: main + footer) */
  .page-nav-wrap {
    flex: 1 1 auto;
    min-width: 0;
    min-height: 0;
    width: 100%;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    overflow: hidden;
  }

  /* When chat open: desktop (1025px+) uses only left area (header/sidebar/content end beside chat) */
  :global(body.page-chat-open) .page-nav-wrap {
    overflow-x: auto;
    min-width: 0;
  }
  @media (min-width: 1025px) {
    :global(body.page-chat-open) .page-nav-wrap {
      width: calc(100% - var(--page-chat-pane-width, 360px)) !important;
      max-width: calc(100% - var(--page-chat-pane-width, 360px)) !important;
      flex: 0 0 auto;
    }
  }

  /* Scroll area containing main + footer */
  .page-scroll-wrap {
    flex: 1 1 auto;
    min-height: 0;
    min-width: 0;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .main-frame {
    width: 100% !important;
    margin-left: 0 !important;
    padding-left: 0 !important;
    flex: 1 1 auto;
    min-width: 0;
  }

  /* Mobile/narrow: bottom padding when chat opens as bottom sheet (70%) */
  @media (max-width: 1024px) {
    :global(body.page-chat-open) .page-nav-wrap {
      padding-bottom: 70vh;
    }
  }

  .header {
    position: relative;
    top: 0;
    left: 0;
    z-index: 100;
    flex-shrink: 0;
    width: 100%;
    max-width: 100%;
    min-width: 0;
  }
  /* Desktop with chat open: fixed header leaves room for chat on the right */
  @media (min-width: 1025px) {
    :global(body.page-chat-open) .header {
      width: calc(100vw - var(--page-chat-pane-width, 360px));
      max-width: calc(100vw - var(--page-chat-pane-width, 360px));
    }
  }

  /* Footer: scrolls with main */
  .page-footer {
    margin-top: auto;
    background: var(--page-bg);
    border-top: 1px solid var(--page-border);
    z-index: 10;
    padding: var(--page-space-6) var(--page-space-8);
  }

  .page-footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .page-footer-left {
    display: flex;
    align-items: center;
  }

  .page-footer-copyright {
    margin: 0;
    font-size: var(--page-font-size-sm);
    color: var(--page-text-secondary);
    font-weight: var(--page-font-weight-medium);
  }

  /* Footer in dark theme */
  [data-theme="dark"] .page-footer {
    background: var(--page-bg-secondary);
    border-top-color: var(--page-border);
  }

  [data-theme="dark"] .page-footer-copyright {
    color: var(--page-text-secondary);
  }

  /* Responsive footer */
  @media (max-width: 768px) {
    .page-footer {
      padding: var(--page-space-4) var(--page-space-6);
    }

    .page-footer-content {
      flex-direction: column;
      gap: var(--page-space-2);
      text-align: center;
    }
  }
</style>
