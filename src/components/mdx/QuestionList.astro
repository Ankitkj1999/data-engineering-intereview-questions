---
import ProgressBar from "../ui/ProgressBar.astro";

interface Props {
  topic: string;
  storagePrefix: string;
}

const { topic, storagePrefix } = Astro.props;
---

<section class="ql" data-prefix={storagePrefix}>

  <!-- Stats bar -->
  <div class="ql-stats">
    <!-- Done stat -->
    <div class="ql-stat">
      <div class="ql-stat-icon ql-stat-icon--done" aria-hidden="true">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="2.5 8.5 6 12 13.5 4.5"/>
        </svg>
      </div>
      <div class="ql-stat-body">
        <span class="ql-stat-value">
          <span class="ql-done-count">0</span><span class="ql-sep">/</span><span class="ql-total">0</span>
        </span>
        <span class="ql-stat-label">Completed</span>
      </div>
    </div>

    <!-- Divider -->
    <div class="ql-divider" aria-hidden="true"></div>

    <!-- Saved stat -->
    <div class="ql-stat">
      <div class="ql-stat-icon ql-stat-icon--saved" aria-hidden="true">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 2h10v13l-5-3-5 3V2z"/>
        </svg>
      </div>
      <div class="ql-stat-body">
        <span class="ql-stat-value ql-bookmark-count">0</span>
        <span class="ql-stat-label">Saved</span>
      </div>
    </div>

    <!-- Progress bar fills remaining space -->
    <div class="ql-progress-wrap">
      <ProgressBar value={0} label="Section progress" class="ql-progress-bar" />
      <span class="ql-progress-pct">0%</span>
    </div>
  </div>

  <!-- Cards -->
  <div class="ql-body">
    <slot />
  </div>

</section>

<script>
  function initList(section: HTMLElement) {
    const cards        = section.querySelectorAll<HTMLElement>(".qc");
    const doneEl       = section.querySelector<HTMLElement>(".ql-done-count")!;
    const totalEl      = section.querySelector<HTMLElement>(".ql-total")!;
    const bookmarkEl   = section.querySelector<HTMLElement>(".ql-bookmark-count")!;
    const fill         = section.querySelector<HTMLElement>(".ql-progress-bar .ds-progress-fill")!;
    const pctEl        = section.querySelector<HTMLElement>(".ql-progress-pct")!;
    const wrap         = section.querySelector<HTMLElement>(".ql-progress-bar")!;

    function update() {
      let done = 0, saved = 0;
      const total = cards.length;

      cards.forEach((card) => {
        const qid = card.dataset.questionId!;
        try {
          const raw = localStorage.getItem(`q_${qid}`);
          if (raw) {
            const st = JSON.parse(raw);
            if (st.done)  done++;
            if (st.saved) saved++;
          }
        } catch (_) {}
      });

      const pct = total > 0 ? Math.round((done / total) * 100) : 0;

      doneEl.textContent     = String(done);
      totalEl.textContent    = String(total);
      bookmarkEl.textContent = String(saved);
      fill.style.width       = `${pct}%`;
      pctEl.textContent      = `${pct}%`;
      wrap.setAttribute("aria-valuenow", String(pct));
    }

    update();
    document.addEventListener("qc:change", update);
  }

  document.querySelectorAll<HTMLElement>(".ql").forEach(initList);
</script>

<style>
  .ql {
    margin-top: 0;
    margin-bottom: 2rem;
  }

  /* ── Stats bar ──────────────────────────────────────────────── */
  .ql-stats {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0.625rem 0.875rem;
    border: 1.5px solid var(--page-border);
    border-radius: var(--page-radius-lg);
    background: var(--page-bg-secondary);
    margin-bottom: 0.875rem;
  }

  /* Individual stat block */
  .ql-stat {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    margin: 0;
  }

  .ql-stat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--page-radius-lg);
    flex-shrink: 0;
  }

  .ql-stat-icon svg {
    width: 14px;
    height: 14px;
  }

  .ql-stat-icon--done {
    background: color-mix(in srgb, var(--brand-green) 14%, transparent);
    color: var(--brand-green);
    border: 1px solid color-mix(in srgb, var(--brand-green) 25%, transparent);
  }

  .ql-stat-icon--saved {
    background: color-mix(in srgb, var(--sl-color-accent) 14%, transparent);
    color: var(--sl-color-accent);
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 25%, transparent);
  }

  .ql-stat-body {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .ql-stat-value {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--sl-color-text);
    letter-spacing: -0.01em;
  }

  .ql-sep {
    font-weight: 400;
    color: var(--sl-color-gray-3);
    margin: 0 0.1em;
  }

  .ql-stat-label {
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Vertical divider */
  .ql-divider {
    width: 1px;
    height: 28px;
    background: var(--page-border);
    margin: 0 0.875rem;
    flex-shrink: 0;
  }

  /* ── Progress bar ─────────────────────────────────────────── */
  .ql-progress-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin: 0 0 0 0.875rem;
    min-width: 0;
  }

  .ql-progress-wrap :global(.ql-progress-bar) {
    flex: 1;
    height: 6px;
    min-width: 0;
  }

  .ql-progress-pct {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--sl-color-gray-3);
    white-space: nowrap;
    min-width: 2.6em;
    text-align: right;
    letter-spacing: -0.01em;
  }

  /* ── Card container ──────────────────────────────────────────── */
  .ql-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 0;
  }

  /* Cards in a list sit closer together than standalone ones — spacing
     comes from .ql-body's flex gap, so each card's own margin is zeroed,
     and horizontal padding tightens slightly. Everything else (radius,
     border, shadow) is QuestionCard's own default; nothing else to
     override here. */
  .ql-body :global(.qc) {
    --_pad-x: 1rem;
    margin-bottom: 0;
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 540px) {
    .ql-stats {
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .ql-progress-wrap {
      margin-left: 0;
      width: 100%;
      flex-basis: 100%;
    }

    .ql-divider {
      display: none;
    }
  }
</style>
