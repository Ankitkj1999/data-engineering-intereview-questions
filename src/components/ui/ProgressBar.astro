---
interface Props {
	value: number;
	max?: number;
	label?: string;
	class?: string;
}

const { value, max = 100, label, class: className } = Astro.props;
const pct = max > 0 ? Math.min(100, Math.max(0, (value / max) * 100)) : 0;
---

<div
	class:list={["ds-progress-track", className]}
	role="progressbar"
	aria-valuenow={value}
	aria-valuemin={0}
	aria-valuemax={max}
	aria-label={label}
>
	<span class="ds-progress-fill" style={`width:${pct}%`}></span>
</div>
