    { id:"latency-vs-geoproximity-vs-geolocation-routing", label:"Latency vs Geoproximity vs Geolocation Routing", desc:"Latency routing picks the lowest-latency region; Geoproximity routes by geographic distance with bias adjustment; Geolocation routes strictly by user location or compliance needs." },
