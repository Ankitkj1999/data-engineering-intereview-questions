    { id:"swf-vs-step-functions-vs-sqs", label:"SWF vs Step Functions vs SQS", desc:"SWF is legacy workflow orchestration; Step Functions is its modern, visual, serverless successor; SQS is a simple queue, not an orchestrator." },
    { id:"alb-vs-nlb-vs-clb",      label:"ALB vs NLB vs CLB",                  desc:"ALB operates at Layer 7 for HTTP/gRPC routing; NLB operates at Layer 4 for extreme performance and static IPs; CLB is the legacy load balancer." },
    { id:"cloudtrail-vs-cloudwatch", label:"CloudTrail vs CloudWatch",         desc:"CloudTrail logs who did what (API activity for auditing); CloudWatch monitors what's happening (metrics, logs, and alarms for operational health)." },
    { id:"datasync-vs-storage-gateway", label:"DataSync vs Storage Gateway",   desc:"DataSync performs fast, one-time or scheduled bulk transfers; Storage Gateway provides ongoing, low-latency hybrid access to AWS storage." },
    { id:"global-accelerator-vs-cloudfront", label:"Global Accelerator vs CloudFront", desc:"Global Accelerator optimizes network paths for any TCP/UDP application using anycast IPs; CloudFront is a caching CDN for HTTP(S) content." },
