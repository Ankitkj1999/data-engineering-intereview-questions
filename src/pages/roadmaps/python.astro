---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
---

<StarlightPage
  frontmatter={{
    title: "Python Roadmap",
    description: "",
  }}
>
  <div id="rm-root">
    <!-- Header -->
    <div class="rm-header">
      <div class="rm-header-left">
        <span class="rm-badge">Roadmap</span>
        <h1 class="rm-title">Python</h1>
        <p class="rm-subtitle">Step-by-step guide to learning Python for data engineering</p>
      </div>
      <div class="rm-header-right">
        <div class="rm-legend">
          <span class="rm-legend-item" data-status="pending"><span class="rm-dot"></span>Pending</span>
          <span class="rm-legend-item" data-status="inprogress"><span class="rm-dot"></span>In Progress</span>
          <span class="rm-legend-item" data-status="done"><span class="rm-dot"></span>Done</span>
        </div>
        <div class="rm-progress-summary">
          <span class="rm-prog-label">Progress</span>
          <div class="rm-prog-bar-wrap"><div class="rm-prog-bar" id="rm-prog-bar"></div></div>
          <span class="rm-prog-pct" id="rm-prog-pct">0%</span>
        </div>
      </div>
    </div>

    <!-- Roadmap flow — populated by JS -->
    <div class="rm-flow" id="rm-flow"></div>

    <!-- Drawer -->
    <div class="rm-drawer" id="rm-drawer">
      <div class="rm-backdrop" id="rm-backdrop"></div>
      <div class="rm-panel">
        <div class="rm-panel-header">
          <div>
            <span id="rm-panel-badge" class="rm-panel-badge"></span>
            <h2 id="rm-panel-title" class="rm-panel-title"></h2>
          </div>
          <button id="rm-panel-close" class="rm-panel-close" aria-label="Close">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="1" y1="1" x2="13" y2="13"/><line x1="13" y1="1" x2="1" y2="13"/>
            </svg>
          </button>
        </div>
        <div class="rm-panel-status-row">
          <span class="rm-panel-status-label">Status</span>
          <div class="rm-status-select-wrap">
            <span class="rm-status-dot" id="rm-status-dot"></span>
            <select class="rm-status-select" id="rm-status-select" aria-label="Set status">
              <option value="pending">⬜ Pending</option>
              <option value="inprogress">🟡 In Progress</option>
              <option value="done">✅ Done</option>
            </select>
          </div>
        </div>
        <div class="rm-panel-body" id="rm-panel-body"></div>
      </div>
    </div>
  </div>
</StarlightPage>

<style is:global>
  @import "/src/styles/roadmap.css";
</style>

<script>
const ROADMAP = [
  { id:"learn-basics", label:"Learn the Basics", desc:"The foundation of Python — syntax, data types, control flow, and built-in structures.", subs:[
    { id:"basic-syntax",      label:"Basic Syntax",             desc:"Indentation rules, comments, print statements, and the Python REPL." },
    { id:"vars-datatypes",    label:"Variables & Data Types",   desc:"int, float, str, bool, None — and dynamic typing in Python." },
    { id:"conditionals",      label:"Conditionals",             desc:"if / elif / else, ternary expressions, and truthy/falsy values." },
    { id:"loops",             label:"Loops",                    desc:"for loops, while loops, break, continue, and range()." },
    { id:"type-casting",      label:"Type Casting",             desc:"Converting between types: int(), str(), float(), list(), etc." },
    { id:"exceptions",        label:"Exceptions",               desc:"try/except/finally, raising exceptions, and custom exception classes." },
    { id:"functions",         label:"Functions & Builtins",     desc:"Defining functions, *args, **kwargs, and useful builtins like map(), filter(), zip()." },
    { id:"lists",             label:"Lists",                    desc:"Mutable ordered sequences — indexing, slicing, list methods." },
    { id:"tuples",            label:"Tuples",                   desc:"Immutable sequences — packing, unpacking, named tuples." },
    { id:"sets",              label:"Sets",                     desc:"Unordered unique collections — set operations, frozenset." },
    { id:"dicts",             label:"Dictionaries",             desc:"Key-value stores — dict comprehensions, .get(), .items(), .update()." },
  ]},
  { id:"data-structures", label:"Data Structures & Algorithms", desc:"Classic CS concepts implemented in Python — essential for technical interviews.", subs:[
    { id:"arrays-ll",         label:"Arrays and Linked Lists",  desc:"Python lists as arrays, implementing singly/doubly linked lists." },
    { id:"hash-tables",       label:"Hash Tables",              desc:"Dictionaries under the hood — hashing and collision handling." },
    { id:"heaps-stacks",      label:"Heaps, Stacks & Queues",   desc:"heapq module, collections.deque, and stack patterns with lists." },
    { id:"bst",               label:"Binary Search Tree",       desc:"BST properties, insertion, search, and traversal algorithms." },
    { id:"recursion",         label:"Recursion",                desc:"Base cases, call stacks, memoization, and tail recursion patterns." },
    { id:"sorting",           label:"Sorting Algorithms",       desc:"Built-in sort(), Timsort, and implementing merge/quick sort." },
  ]},
  { id:"modules", label:"Modules", desc:"Organising code with modules, packages, and the Python import system.", subs:[
    { id:"builtin-modules",   label:"Builtin Modules",          desc:"os, sys, math, datetime, json, pathlib, collections, itertools." },
    { id:"custom-modules",    label:"Custom Modules",           desc:"Creating __init__.py, relative vs absolute imports, __all__." },
  ]},
  { id:"lambdas",          label:"Lambdas",                  desc:"Anonymous functions with lambda — usage with map(), filter(), sorted(), and functional patterns.", subs:[] },
  { id:"decorators",       label:"Decorators",               desc:"Higher-order functions that wrap other functions — functools.wraps, class decorators, stacking decorators.", subs:[] },
  { id:"iterators",        label:"Iterators",                desc:"__iter__ and __next__ protocols, itertools module, lazy evaluation.", subs:[] },
  { id:"regex",            label:"Regular Expressions",      desc:"Pattern matching with the re module — compile, match, search, findall, groups.", subs:[] },
  { id:"oop", label:"Object Oriented Programming", desc:"Python's OOP model — classes, inheritance, magic methods, and encapsulation.", subs:[
    { id:"classes",           label:"Classes",                  desc:"__init__, instance vs class attributes, @classmethod, @staticmethod, @property." },
    { id:"inheritance",       label:"Inheritance",              desc:"Single/multiple inheritance, super(), MRO (Method Resolution Order)." },
    { id:"dunder",            label:"Methods & Dunder",         desc:"__str__, __repr__, __len__, __eq__, __hash__, and operator overloading." },
  ]},
  { id:"pkg-managers", label:"Package Managers", desc:"Tools for installing, managing, and isolating Python dependencies.", subs:[
    { id:"pip",               label:"pip",                      desc:"The standard Python package installer — pip install, requirements.txt, pip freeze." },
    { id:"pypi",              label:"PyPI",                     desc:"The Python Package Index — finding, publishing, and versioning packages." },
    { id:"poetry",            label:"Poetry",                   desc:"Modern dependency management with pyproject.toml, lock files, and virtual envs." },
    { id:"conda",             label:"Conda",                    desc:"Package and environment manager from Anaconda — great for data science." },
    { id:"uv",                label:"uv",                       desc:"Ultra-fast Python package and project manager written in Rust." },
    { id:"pipenv",            label:"Pipenv",                   desc:"Combines pip and virtualenv — Pipfile and Pipfile.lock." },
    { id:"virtualenv",        label:"virtualenv",               desc:"Creating isolated Python environments." },
    { id:"pyenv",             label:"pyenv",                    desc:"Managing multiple Python versions on the same machine." },
    { id:"pyproject",         label:"pyproject.toml",           desc:"The modern Python project configuration standard (PEP 517/518)." },
  ]},
  { id:"list-comp",        label:"List Comprehensions",      desc:"Concise syntax for building lists — [expr for x in iterable if condition].", subs:[] },
  { id:"gen-expr",         label:"Generator Expressions",    desc:"Lazy evaluation with (expr for x in iterable) — memory-efficient alternative to list comprehensions.", subs:[] },
  { id:"paradigms",        label:"Paradigms",                desc:"Python as a multi-paradigm language — functional, procedural, and OOP patterns.", subs:[] },
  { id:"context-mgr",     label:"Context Manager",          desc:"The with statement, __enter__/__exit__, contextlib, and resource management patterns.", subs:[] },
  { id:"frameworks", label:"Learn a Framework", desc:"Web and async frameworks for building APIs, dashboards, and services with Python.", subs:[
    { id:"fastapi",           label:"FastAPI",                  desc:"Modern, high-performance web API framework with automatic docs and type hints." },
    { id:"django",            label:"Django",                   desc:"Batteries-included web framework — ORM, admin, auth, templates." },
    { id:"flask",             label:"Flask",                    desc:"Lightweight WSGI microframework — great for small APIs and services." },
    { id:"aiohttp",           label:"aiohttp",                  desc:"Async HTTP client/server framework built on asyncio." },
    { id:"tornado",           label:"Tornado",                  desc:"Non-blocking network I/O and web framework." },
    { id:"sanic",             label:"Sanic",                    desc:"Fast async web server and framework, built for speed." },
    { id:"dash",              label:"Plotly Dash",              desc:"Build interactive analytical web apps in pure Python." },
    { id:"pyramid",           label:"Pyramid",                  desc:"Flexible web framework — scales from simple to complex apps." },
    { id:"gevent",            label:"gevent",                   desc:"Coroutine-based networking library using greenlets." },
  ]},
  { id:"concurrency", label:"Concurrency", desc:"Running tasks simultaneously in Python — threads, processes, and async.", subs:[
    { id:"gil",               label:"GIL",                      desc:"The Global Interpreter Lock — what it is, why it exists, and its impact on threading." },
    { id:"threading",         label:"Threading",                desc:"Thread-based parallelism with the threading module — I/O-bound tasks." },
    { id:"multiprocessing",   label:"Multiprocessing",          desc:"Process-based parallelism — bypassing the GIL for CPU-bound tasks." },
    { id:"asyncio",           label:"Asynchrony (asyncio)",     desc:"Cooperative multitasking with async/await, event loops, and coroutines." },
  ]},
  { id:"static-typing", label:"Static Typing", desc:"Adding type annotations to Python — improving code quality and IDE support.", subs:[
    { id:"typing-mod",        label:"typing module",            desc:"List, Dict, Optional, Union, Callable, TypeVar, and Protocol." },
    { id:"pydantic",          label:"Pydantic",                 desc:"Data validation using Python type hints — widely used in FastAPI." },
    { id:"mypy",              label:"mypy",                     desc:"Static type checker for Python — catches type errors before runtime." },
    { id:"pyright",           label:"pyright",                  desc:"Fast type checker from Microsoft — powers Pylance in VS Code." },
    { id:"pyre",              label:"pyre",                     desc:"Type checker from Meta — designed for large codebases." },
  ]},
  { id:"code-fmt", label:"Code Formatting", desc:"Keeping Python code consistent, readable, and style-guide compliant.", subs:[
    { id:"ruff",              label:"ruff",                     desc:"Extremely fast Python linter and formatter written in Rust — replaces flake8 + isort." },
    { id:"black",             label:"black",                    desc:"The uncompromising code formatter — opinionated, zero-config formatting." },
    { id:"yapf",              label:"yapf",                     desc:"Yet Another Python Formatter from Google — highly configurable." },
    { id:"sphinx",            label:"Sphinx",                   desc:"Documentation generator — reStructuredText, autodoc, and Read the Docs." },
  ]},
  { id:"common-pkgs",      label:"Common Packages",          desc:"Essential Python packages for data engineering: NumPy, Pandas, requests, SQLAlchemy, and more.", subs:[] },
  { id:"testing", label:"Testing", desc:"Writing tests to verify correctness — unit, integration, and property-based testing.", subs:[
    { id:"pytest",            label:"pytest",                   desc:"The most popular Python testing framework — fixtures, parametrize, plugins." },
    { id:"unittest",          label:"unittest / pyUnit",        desc:"Python's built-in testing framework based on xUnit patterns." },
    { id:"doctest",           label:"doctest",                  desc:"Tests embedded in docstrings — simple and self-documenting." },
    { id:"tox",               label:"tox",                      desc:"Automate testing across multiple Python versions and environments." },
    { id:"nose",              label:"nose",                     desc:"Test runner extending unittest — largely superseded by pytest." },
  ]},
];

// ── Icons ─────────────────────────────────────────────────────────────────────
const ICON_PENDING    = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="6"/></svg>`;
const ICON_INPROGRESS = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="6"/><polyline points="8 5 8 8 10 10"/></svg>`;
const ICON_DONE       = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="6"/><polyline points="5.5 8.5 7 10 10.5 6"/></svg>`;
const ICON_ARROW      = `<svg width="20" height="28" viewBox="0 0 20 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="10" y1="0" x2="10" y2="20"/><polyline points="5 15 10 22 15 15"/></svg>`;
const ICON_CHEVRON    = `<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 5 7 9 11 5"/></svg>`;

function iconFor(s: string) {
  if (s === "done") return ICON_DONE;
  if (s === "inprogress") return ICON_INPROGRESS;
  return ICON_PENDING;
}

// ── State ─────────────────────────────────────────────────────────────────────
const KEY = "py_roadmap_v2";
function load(): Record<string, string> {
  try { return JSON.parse(localStorage.getItem(KEY) || "{}"); } catch { return {}; }
}
function save(s: Record<string, string>) {
  localStorage.setItem(KEY, JSON.stringify(s));
}

let state = load();
function getS(id: string) { return state[id] || "pending"; }

// ── Progress ──────────────────────────────────────────────────────────────────
function allIds() {
  const ids: string[] = [];
  for (const t of ROADMAP) { ids.push(t.id); for (const s of t.subs) ids.push(s.id); }
  return ids;
}

function refreshProgress() {
  const ids = allIds();
  const done = ids.filter(id => getS(id) === "done").length;
  const pct  = ids.length ? Math.round((done / ids.length) * 100) : 0;
  const bar  = document.getElementById("rm-prog-bar");
  const pctEl = document.getElementById("rm-prog-pct");
  if (bar)   bar.style.width = `${pct}%`;
  if (pctEl) pctEl.textContent = `${pct}%`;
}

// ── Build flow ────────────────────────────────────────────────────────────────
function buildFlow() {
  const flow = document.getElementById("rm-flow");
  if (!flow) return;
  flow.innerHTML = "";

  ROADMAP.forEach((topic, ti) => {
    const s = getS(topic.id);

    // Topic node
    const topicEl = document.createElement("div");
    topicEl.className = `rm-topic-node${s !== "pending" ? ` is-${s}` : ""}`;
    topicEl.dataset.id = topic.id;
    topicEl.innerHTML = `
      <span class="rm-topic-icon">${iconFor(s)}</span>
      <span class="rm-topic-label">${topic.label}</span>
      ${topic.subs.length ? `<span class="rm-count-badge">${topic.subs.length}</span>` : ""}
      <span class="rm-chevron">${ICON_CHEVRON}</span>
    `;
    topicEl.addEventListener("click", () => openPanel(topic.id, "topic"));
    flow.appendChild(topicEl);

    // Subtopics
    if (topic.subs.length > 0) {
      const group = document.createElement("div");
      group.className = "rm-sub-group";
      group.dataset.parent = topic.id;

      for (const sub of topic.subs) {
        const ss = getS(sub.id);
        const subEl = document.createElement("div");
        subEl.className = `rm-sub-node${ss !== "pending" ? ` is-${ss}` : ""}`;
        subEl.dataset.id = sub.id;
        subEl.innerHTML = `
          <span class="rm-sub-icon">${iconFor(ss)}</span>
          <span class="rm-sub-label">${sub.label}</span>
        `;
        subEl.addEventListener("click", () => openPanel(sub.id, "subtopic", topic.id));
        group.appendChild(subEl);
      }
      flow.appendChild(group);
    }

    // Arrow between sections
    if (ti < ROADMAP.length - 1) {
      const arrow = document.createElement("div");
      arrow.className = "rm-arrow";
      arrow.innerHTML = ICON_ARROW;
      flow.appendChild(arrow);
    }
  });
}

// ── Panel (drawer) ────────────────────────────────────────────────────────────
let activeId: string | null = null;
let activeParent: string | null = null;

function findItem(id: string): any {
  for (const t of ROADMAP) {
    if (t.id === id) return { ...t, type: "topic" };
    for (const s of t.subs) { if (s.id === id) return { ...s, type: "subtopic" }; }
  }
  return null;
}

function openPanel(id: string, type: string, parentId?: string) {
  activeId     = id;
  activeParent = parentId ?? null;

  const item = findItem(id);
  if (!item) return;

  const badge = document.getElementById("rm-panel-badge")!;
  const title = document.getElementById("rm-panel-title")!;
  const body  = document.getElementById("rm-panel-body")!;

  badge.textContent = type === "topic" ? "Topic" : "Subtopic";
  badge.className   = `rm-panel-badge is-${type}`;
  title.textContent = item.label;
  body.innerHTML    = `<p class="rm-panel-desc">${item.desc}</p>` + (item.link ? `<a href="${item.link}" class="rm-read-more">Read more →</a>` : "");

  if (type === "topic" && item.subs?.length > 0) {
    const sublist = document.createElement("div");
    sublist.className = "rm-panel-sublist";
    sublist.innerHTML = `<p class="rm-panel-sublist-title">Subtopics (${item.subs.length})</p>`;
    for (const sub of item.subs) {
      const ss = getS(sub.id);
      const row = document.createElement("div");
      row.className = `rm-panel-subitem${ss !== "pending" ? ` is-${ss}` : ""}`;
      row.dataset.subId = sub.id;
      row.innerHTML = `
        <span class="rm-panel-subitem-icon">${iconFor(ss)}</span>
        <span class="rm-panel-subitem-label">${sub.label}</span>
        <span class="rm-panel-subitem-tag">${ss}</span>
      `;
      row.addEventListener("click", (e) => {
        e.stopPropagation();
        openPanel(sub.id, "subtopic", id);
      });
      sublist.appendChild(row);
    }
    body.appendChild(sublist);
  }

  syncStatusBtns();
  document.getElementById("rm-drawer")!.classList.add("is-open");
  if (document.body.classList.contains("page-chat-open")) {
    document.body.classList.remove("page-chat-open");
    try { sessionStorage.setItem("page-chat-open", "0"); } catch (_) {}
    document.body.dispatchEvent(new CustomEvent("page-chat-toggle"));
  }
  document.body.style.overflow = "hidden";
}

function closePanel() {
  document.getElementById("rm-drawer")!.classList.remove("is-open");
  document.body.style.overflow = "";
  activeId = activeParent = null;
}

function syncStatusBtns() {
  if (!activeId) return;
  const s = getS(activeId);
  const sel = document.getElementById("rm-status-select") as HTMLSelectElement;
  const dot = document.getElementById("rm-status-dot");
  if (sel) { sel.value = s; sel.className = `rm-status-select${s !== "pending" ? ` is-${s}` : ""}`; }
  if (dot) dot.className = `rm-status-dot${s !== "pending" ? ` is-${s}` : ""}`;
}

function setStatus(id: string, s: string) {
  state[id] = s;
  save(state);
  buildFlow();
  refreshProgress();
  syncStatusBtns();
  // Refresh subitem row if panel is showing a topic
  if (activeParent) {
    const row = document.querySelector<HTMLElement>(`.rm-panel-subitem[data-sub-id="${id}"]`);
    if (row) {
      row.className = `rm-panel-subitem${s !== "pending" ? ` is-${s}` : ""}`;
      row.dataset.subId = id;
      const icon = row.querySelector(".rm-panel-subitem-icon");
      const tag  = row.querySelector(".rm-panel-subitem-tag");
      if (icon) icon.innerHTML = iconFor(s);
      if (tag)  tag.textContent = s;
    }
  }
}

// ── Wire up ───────────────────────────────────────────────────────────────────
buildFlow();
refreshProgress();

document.body.appendChild(document.getElementById("rm-drawer")!);
document.getElementById("rm-panel-close")?.addEventListener("click", closePanel);
document.getElementById("rm-backdrop")?.addEventListener("click", closePanel);
document.addEventListener("keydown", e => { if (e.key === "Escape") closePanel(); });
document.body.addEventListener("page-chat-toggle", () => {
  if (document.body.classList.contains("page-chat-open")) closePanel();
});

document.getElementById("rm-status-select")?.addEventListener("change", (e) => {
  if (!activeId) return;
  setStatus(activeId, (e.target as HTMLSelectElement).value);
});
</script>
